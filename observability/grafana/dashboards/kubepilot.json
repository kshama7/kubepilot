{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["kubepilot", "sre"],
  "title": "KubePilot — Reliability Overview",
  "uid": "kubepilot-overview",
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Cluster Health Score",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "kubepilot_cluster_health_score", "legendFormat": "{{cluster_id}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Findings by Severity (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (severity) (rate(kubepilot_recommendations_total[5m]))", "legendFormat": "{{severity}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Analysis Runs by Outcome",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line" } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (analyzer, outcome) (rate(kubepilot_analysis_duration_seconds_count[5m]))", "legendFormat": "{{analyzer}} / {{outcome}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Analysis Duration p95 by Analyzer",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, analyzer) (rate(kubepilot_analysis_duration_seconds_bucket[5m])))", "legendFormat": "{{analyzer}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "API Latency p95 by Route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, route) (rate(kubepilot_api_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Total Findings by Analyzer",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        { "expr": "sum by (analyzer) (kubepilot_recommendations_total)", "legendFormat": "{{analyzer}}", "refId": "A" }
      ]
    }
  ]
}
